# 听译配置示例（复制为 .env，勿提交）

# 识别模式：local | cloud | hybrid（默认 hybrid = 本地优先，云端回退）
TINGYI_ASR_MODE=hybrid

# --- 本地引擎 ---
TINGYI_LOCAL_ENGINE=sensevoice
TINGYI_LOCAL_MODEL_SIZE=small
TINGYI_LOCAL_DEVICE=cpu
TINGYI_LOCAL_COMPUTE_TYPE=int8
TINGYI_LOCAL_LANGUAGE=zh

# --- 云端（可选）---
# OpenAI Whisper API 或任意 OpenAI 兼容端点
TINGYI_CLOUD_PROVIDER=openai
TINGYI_CLOUD_API_KEY=
TINGYI_CLOUD_BASE_URL=https://api.openai.com/v1
TINGYI_CLOUD_MODEL=whisper-1
TINGYI_CLOUD_LANGUAGE=zh
