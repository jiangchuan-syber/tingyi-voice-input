# 听译配置示例（复制为 .env，勿提交）
# DeepSeek 配置可与「工作经历挖掘」项目共用同一套变量名

# 识别模式：local | cloud | hybrid
TINGYI_ASR_MODE=hybrid

# --- 本地引擎 ---
TINGYI_LOCAL_ENGINE=sensevoice
TINGYI_LOCAL_MODEL_SIZE=small
TINGYI_LOCAL_DEVICE=cpu
TINGYI_LOCAL_COMPUTE_TYPE=int8
TINGYI_LOCAL_LANGUAGE=zh

# --- 桌面热键与粘贴 ---
TINGYI_HOTKEY_RECORD=f9
TINGYI_AUTO_PASTE=true

# --- VAD 停顿检测（毫秒）---
TINGYI_VAD_MIN_SILENCE_MS=500

# --- 个人词典与润色 ---
TINGYI_DICTIONARY_ENABLED=true
# TINGYI_DICTIONARY_PATH=e:\tingyi\dictionary.json
TINGYI_RULE_REFINE_ENABLED=true
# 有 DEEPSEEK_API_KEY 时默认开启 LLM 润色；设为 false 可关闭
# TINGYI_REFINE_ENABLED=auto
# true=先贴草稿，后台 DeepSeek 润色后替换；false=等润色完再贴
TINGYI_REFINE_ASYNC=true

# --- DeepSeek（与 e:\工作经历挖掘\.env 相同变量名，可复制粘贴）---
DEEPSEEK_API_KEY=
# DEEPSEEK_API_BASE=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-v4-flash
# 也可单独覆盖润色模型：
# TINGYI_REFINE_MODEL=deepseek-chat

# --- 云端 ASR（可选）---
TINGYI_CLOUD_PROVIDER=openai
TINGYI_CLOUD_API_KEY=
TINGYI_CLOUD_BASE_URL=https://api.openai.com/v1
TINGYI_CLOUD_MODEL=whisper-1
TINGYI_CLOUD_LANGUAGE=zh
